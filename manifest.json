{
  "manifest_version": 3,
  "name": "Stremio Launcher – Open from IMDb & Google",
  "description": "Quickly open movies and TV shows in Stremio from IMDb, Google search, or the right-click menu.",
  "version": "1.0",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.imdb.com/*", 
        "*://*.google.com/*",
        "*://*.google.co.uk/*",
        "*://*.google.ca/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": [
        "*://*.imdb.com/*",
        "*://*.google.com/*",
        "*://*.google.co.uk/*",
        "*://*.google.ca/*"
      ]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "contextMenus",
    "tabs"
  ]  
}